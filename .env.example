# Football Coach LLM — copy to .env and adjust

# Provider: auto | ollama | ngrok
COACH_LLM_PROVIDER=auto

# Remote ngrok instance (Football Coach model)
COACH_LLM_BASE_URL=https://lashonda-overfoul-demandingly.ngrok-free.dev

# Local Ollama alternative:
# COACH_LLM_PROVIDER=ollama
# COACH_LLM_BASE_URL=http://localhost:11434

COACH_LLM_MAX_TOKENS=800
COACH_LLM_TIMEOUT=120

# Legacy Gemini (not used by default report/assistant paths)
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-flash-lite-latest

# Dashboard dev (optional)
# VITE_API_URL=
